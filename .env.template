# =============================================================================
# Autonomous ETL Agent — Environment Variables Template
# Copy to .env and fill in your values. Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic Claude
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Claude model to use (claude-3-5-sonnet-20241022 recommended)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Max tokens for code generation responses
ANTHROPIC_MAX_TOKENS=8192

# -----------------------------------------------------------------------------
# GCP Configuration
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Path to service account key JSON (leave empty to use Application Default Credentials)
GOOGLE_APPLICATION_CREDENTIALS=

# GCS Bucket names (will be created by Terraform)
GCS_RAW_BUCKET=your_project_id-raw-data
GCS_PROCESSED_BUCKET=your_project_id-processed-data
GCS_ARTIFACTS_BUCKET=your_project_id-artifacts

# Dataproc
DATAPROC_CLUSTER_NAME=etl-agent-cluster
DATAPROC_REGION=us-central1
DATAPROC_STAGING_BUCKET=your_project_id-artifacts

# Cloud Composer
COMPOSER_ENVIRONMENT=etl-agent-composer
COMPOSER_BUCKET=your_cloud_composer_bucket

# Secret Manager (secret IDs, not values)
SECRET_GITHUB_TOKEN=etl-agent-github-token
SECRET_ANTHROPIC_KEY=etl-agent-anthropic-key

# -----------------------------------------------------------------------------
# GitHub Integration
# -----------------------------------------------------------------------------
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_OWNER=your_github_username_or_org
GITHUB_REPO_NAME=Autonomous-ETL-Agent
GITHUB_BASE_BRANCH=main

# -----------------------------------------------------------------------------
# FastAPI Application
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# API key for endpoint authentication (generate a strong random string)
API_KEY=your_strong_random_api_key_here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Directory for locally generated artifacts (before GCS upload)
ARTIFACTS_DIR=./artifacts

# Max retries for LLM calls
LLM_MAX_RETRIES=3

# State persistence backend: memory | firestore | postgres
STATE_BACKEND=memory

# Firestore collection (if STATE_BACKEND=firestore)
FIRESTORE_COLLECTION=etl_agent_runs

# Postgres connection string (if STATE_BACKEND=postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/etl_agent
